## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Ignore Visual Studio specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore build outputs
bin/
obj/
[Bb]uild[Ll]og.*

# Ignore NuGet packages
*.nupkg
*.snupkg
packages/
project.lock.json
project.fragment.lock.json
artifacts/

# Ignore Rider/JetBrains specific files
.idea/
*.sln.iml

# Ignore Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Ignore log files
*.log

# Ignore application insights
ApplicationInsights.config

# Ignore publish output
wwwroot/
publish/

# Ignore Resharper files
_ReSharper.Caches/

# Ignore generated files
Form1.Designer.cs
Form1.resx

# Ignore temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo

# Ignore other system files
.DS_Store
*.class
*.pyc
*.pyo
*.pyd
*.pid
*.seed
